# Telegram Bot Token (от @BotFather)
BOT_TOKEN=your_bot_token_here

# Yandex Object Storage
YC_ACCESS_KEY=your_access_key
YC_SECRET_KEY=your_secret_key
YC_BUCKET_NAME=steps-competition
YC_REGION=ru-central1
